{
  "name": "rhymebook-mcp-server",
  "version": "1.0.0",
  "description": "AI-powered music production assistant with 40+ MCP tools for lyrics, beats, and session tracking",
  "type": "module",
  "main": "dist/server/index.js",
  "author": {
    "name": "Anthony M Cavanaugh",
    "email": "cavanaughdesign@gmail.com",
    "url": "https://cavanaughdesignstudio.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cavanaughdesign/rhymebook-mcp-server.git"
  },
  "homepage": "https://github.com/cavanaughdesign/rhymebook-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cavanaughdesign/rhymebook-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "music",
    "lyrics",
    "beats",
    "recording",
    "studio",
    "ai",
    "rhyme",
    "songwriting"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "npm run build:ui:lyric-lab && npm run build:ui:session-tracker && npm run build:ui:beat-explorer && npm run build:ui:audio-player && npm run build:ui:dashboard",
    "build:ui:lyric-lab": "cross-env INPUT=src/ui/tools/lyric-lab.html vite build",
    "build:ui:session-tracker": "cross-env INPUT=src/ui/tools/session-tracker.html vite build",
    "build:ui:beat-explorer": "cross-env INPUT=src/ui/tools/beat-explorer.html vite build",
    "build:ui:audio-player": "cross-env INPUT=src/ui/tools/audio-player.html vite build",
    "build:ui:dashboard": "cross-env INPUT=src/ui/index.html vite build",
    "start": "tsx src/server/index.ts",
    "start:stdio": "tsx src/server/index.ts --stdio",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:ui": "vite",
    "clean": "rimraf dist",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "music-metadata": "^11.12.3",
    "tone": "^15.1.22",
    "wavesurfer.js": "^7.12.2",
    "zod": "^4.3.6",
    "prom-client": "^14.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^10.1.0",
    "rimraf": "^5.0.0",
    "terser": "^5.46.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^3.0.0"
  }
}
